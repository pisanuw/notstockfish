# stockreptile environment template
#
# Copy this file to .env (root), backend/.env, or frontend/.env as needed.
# Do not commit real secrets.

# ---------------------------------------------------------------------------
# Backend auth configuration
# ---------------------------------------------------------------------------

# Google OAuth Client ID used by backend token verification and account config.
# Required only if you want Google sign-in enabled in the app.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Compatibility fallback (optional): if GOOGLE_CLIENT_ID is unset,
# backend/auth.py also checks VITE_GOOGLE_CLIENT_ID.
# Prefer GOOGLE_CLIENT_ID for backend deployments.
VITE_GOOGLE_CLIENT_ID=


# ---------------------------------------------------------------------------
# Frontend runtime configuration (Vite)
# ---------------------------------------------------------------------------

# Backend API base URL used by frontend/src/services/api.ts.
# Leave empty for local development auto-detection, or set for hosted frontend.
# Example:
# VITE_API_URL=https://example.onrender.com
VITE_API_URL=